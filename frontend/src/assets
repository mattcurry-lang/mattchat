<svg xmlns="http://www.w3.org/2000/svg" width="480" height="480" viewBox="0 0 480 480">
  <defs>
    <linearGradient id="brandGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#22d3ee"/>
      <stop offset="50%" stop-color="#3b82f6"/>
      <stop offset="100%" stop-color="#a855f7"/>
    </linearGradient>
    <pattern id="mattchatDoodles" patternUnits="userSpaceOnUse" width="260" height="260" viewBox="0 0 480 480">
      <rect width="480" height="480" fill="#060608"/>

      <!-- ===== Tile group A (top-left) ===== -->
      <g stroke="#22d3ee" stroke-width="2.4" fill="none" stroke-linecap="round" stroke-linejoin="round" opacity="0.9">
        <!-- speech bubble -->
        <path d="M20 30 h60 a10 10 0 0 1 10 10 v28 a10 10 0 0 1 -10 10 h-34 l-14 14 v-14 h-12 a10 10 0 0 1 -10 -10 v-28 a10 10 0 0 1 10 -10 z"/>
        <!-- wifi arcs -->
        <g transform="translate(150,40)">
          <path d="M0 26 a36 36 0 0 1 60 0"/>
          <path d="M10 34 a24 24 0 0 1 40 0"/>
          <path d="M20 42 a12 12 0 0 1 20 0"/>
          <circle cx="30" cy="50" r="3" fill="#22d3ee" stroke="none"/>
        </g>
        <!-- moon -->
        <path d="M260 20 a26 26 0 1 0 26 45 a20 20 0 0 1 -26 -45 z"/>
        <!-- squiggle -->
        <path d="M330 20 q10 15 0 30 q-10 15 0 30 q10 15 0 30"/>
      </g>

      <g stroke="#2dd4bf" stroke-width="2.4" fill="none" stroke-linecap="round" stroke-linejoin="round" opacity="0.85">
        <!-- paw print -->
        <g transform="translate(30,120)">
          <ellipse cx="15" cy="30" rx="16" ry="13"/>
          <ellipse cx="-2" cy="8" rx="6" ry="8"/>
          <ellipse cx="14" cy="0" rx="6" ry="8"/>
          <ellipse cx="30" cy="4" rx="6" ry="8"/>
        </g>
        <!-- flower -->
        <g transform="translate(150,140)">
          <circle cx="0" cy="0" r="6"/>
          <ellipse cx="0" cy="-16" rx="7" ry="11"/>
          <ellipse cx="0" cy="16" rx="7" ry="11"/>
          <ellipse cx="-16" cy="0" rx="11" ry="7"/>
          <ellipse cx="16" cy="0" rx="11" ry="7"/>
          <path d="M0 20 q-4 20 -14 26"/>
        </g>
        <!-- lightning bolt -->
        <path d="M255 100 l-16 26 h12 l-14 26 l24 -30 h-12 z" fill="#2dd4bf" stroke="none" opacity="0.9"/>
        <!-- pi symbol -->
        <text x="320" y="140" font-family="Georgia, serif" font-size="34" fill="#22d3ee" stroke="none">&#960;</text>
      </g>

      <!-- ===== middle band ===== -->
      <g stroke="#22d3ee" stroke-width="2.4" fill="none" stroke-linecap="round" stroke-linejoin="round" opacity="0.85">
        <!-- glasses -->
        <g transform="translate(40,210)">
          <rect x="0" y="0" width="34" height="24" rx="8"/>
          <rect x="50" y="0" width="34" height="24" rx="8"/>
          <path d="M34 10 h16"/>
          <path d="M-10 8 h10"/>
          <path d="M94 8 h10"/>
        </g>
        <!-- long squiggle across -->
        <path d="M150 220 q20 -14 40 0 q20 14 40 0 q20 -14 40 0 q20 14 40 0"/>
        <!-- zzz -->
        <text x="360" y="230" font-family="Arial, sans-serif" font-weight="700" font-size="20" fill="#2dd4bf" stroke="none">zzZ</text>
      </g>

      <g stroke="#2dd4bf" stroke-width="2.4" fill="none" stroke-linecap="round" stroke-linejoin="round" opacity="0.85">
        <!-- spider -->
        <g transform="translate(60,290)">
          <circle cx="0" cy="0" r="16"/>
          <circle cx="-6" cy="-4" r="2.2" fill="#2dd4bf" stroke="none"/>
          <circle cx="6" cy="-4" r="2.2" fill="#2dd4bf" stroke="none"/>
          <path d="M-6 4 q6 6 12 0"/>
          <path d="M-16 -10 l-18 -10"/>
          <path d="M-18 0 l-22 2"/>
          <path d="M-16 10 l-18 12"/>
          <path d="M16 -10 l18 -10"/>
          <path d="M18 0 l22 2"/>
          <path d="M16 10 l18 12"/>
        </g>
        <!-- chat/message icon -->
        <g transform="translate(170,280)">
          <rect x="0" y="0" width="70" height="46" rx="12"/>
          <path d="M18 46 v14 l16 -14"/>
          <circle cx="18" cy="23" r="3" fill="#2dd4bf" stroke="none"/>
          <circle cx="35" cy="23" r="3" fill="#2dd4bf" stroke="none"/>
          <circle cx="52" cy="23" r="3" fill="#2dd4bf" stroke="none"/>
        </g>
        <!-- game controller -->
        <g transform="translate(300,290)">
          <path d="M0 20 q0 -20 20 -20 h30 q20 0 20 20 v6 q0 20 -14 20 q-8 0 -10 -8 h-22 q-2 8 -10 8 q-14 0 -14 -20 z"/>
          <circle cx="16" cy="14" r="2.4" fill="#2dd4bf" stroke="none"/>
          <path d="M10 14 h12"/>
          <path d="M16 8 v12"/>
          <circle cx="55" cy="10" r="2.4" fill="#2dd4bf" stroke="none"/>
          <circle cx="63" cy="16" r="2.4" fill="#2dd4bf" stroke="none"/>
        </g>
      </g>

      <!-- ===== bottom band ===== -->
      <g stroke="#22d3ee" stroke-width="2.4" fill="none" stroke-linecap="round" stroke-linejoin="round" opacity="0.85">
        <!-- rocket -->
        <g transform="translate(30,360)">
          <path d="M14 40 q0 -30 14 -40 q14 10 14 40 q-14 8 -28 0 z"/>
          <circle cx="14" cy="10" r="4"/>
          <path d="M6 30 l-10 14"/>
          <path d="M22 30 l10 14"/>
        </g>
        <!-- leaf -->
        <path d="M140 400 q30 -30 60 -10 q-10 30 -40 34 q-20 2 -20 -24 z" transform="translate(0,-10)"/>
        <path d="M150 400 q20 -14 40 -8"/>
        <!-- musical note -->
        <g transform="translate(260,370)">
          <circle cx="0" cy="30" r="7"/>
          <circle cx="30" cy="24" r="7"/>
          <path d="M7 30 v-30 l30 -6 v30"/>
        </g>
        <!-- sparkle -->
        <path d="M400 350 l4 12 l12 4 l-12 4 l-4 12 l-4 -12 l-12 -4 l12 -4 z" fill="#2dd4bf" stroke="none"/>
      </g>

      <g stroke="#2dd4bf" stroke-width="2" fill="none" opacity="0.7">
        <!-- scattered dots -->
        <circle cx="10" cy="10" r="3" fill="#22d3ee" stroke="none"/>
        <circle cx="450" cy="60" r="3" fill="#22d3ee" stroke="none"/>
        <circle cx="120" cy="440" r="3" fill="#2dd4bf" stroke="none"/>
        <circle cx="420" cy="440" r="3" fill="#22d3ee" stroke="none"/>
        <circle cx="230" cy="60" r="2.5" fill="#2dd4bf" stroke="none"/>
        <circle cx="380" cy="180" r="2.5" fill="#22d3ee" stroke="none"/>
        <circle cx="90" cy="250" r="2.5" fill="#2dd4bf" stroke="none"/>
        <circle cx="440" cy="270" r="2.5" fill="#22d3ee" stroke="none"/>
      </g>

      <!-- ===== Mattchat brand mark (repeated) ===== -->
      <g fill="none" stroke="url(#brandGrad)" stroke-linecap="round" stroke-linejoin="round" opacity="0.95">
        <g transform="translate(415,70) scale(0.62)">
          <ellipse cx="0" cy="12" rx="42" ry="34" stroke-width="7"/>
          <path d="M-20 -16 L-8 -33 L4 -19 L16 -33 L26 -16" stroke-width="7"/>
          <path d="M-8 4 q16 -11 29 3 q9 11 -4 19 q-11 6 -19 -2" stroke-width="6"/>
        </g>
        <g transform="translate(120,430) scale(0.62)">
          <ellipse cx="0" cy="12" rx="42" ry="34" stroke-width="7"/>
          <path d="M-20 -16 L-8 -33 L4 -19 L16 -33 L26 -16" stroke-width="7"/>
          <path d="M-8 4 q16 -11 29 3 q9 11 -4 19 q-11 6 -19 -2" stroke-width="6"/>
        </g>
      </g>
    </pattern>
  </defs>
  <rect width="480" height="480" fill="url(#mattchatDoodles)"/>
</svg>
